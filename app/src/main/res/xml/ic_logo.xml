<?xml version="1.0" encoding="utf-8"?>
<!-- FILE: app/src/main/res/drawable/ic_logo.xml -->
<!-- SugarCare logo: heart + leaf + water drop + arrow -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">

    <!-- ══ LEFT HALF OF HEART (Teal gradient simulation) ══ -->
    <path
        android:fillColor="#2E9B9B"
        android:pathData="
        M100,160
        C100,160 30,110 30,70
        C30,48 48,35 65,35
        C78,35 90,42 100,55
        C100,55 100,160 100,160 Z"/>

    <!-- ══ RIGHT HALF OF HEART (Light steel blue) ══ -->
    <path
        android:fillColor="#90B8C8"
        android:pathData="
        M100,160
        C100,160 170,110 170,70
        C170,48 152,35 135,35
        C122,35 110,42 100,55
        C100,55 100,160 100,160 Z"/>

    <!-- ══ DOTS on right side ══ -->
    <path android:fillColor="#6A9AB0" android:pathData="M163,60 A4,4 0 1,1 163,59.9 Z"/>
    <path android:fillColor="#6A9AB0" android:pathData="M168,73 A3.5,3.5 0 1,1 168,72.9 Z"/>
    <path android:fillColor="#6A9AB0" android:pathData="M166,86 A3,3 0 1,1 166,85.9 Z"/>

    <!-- ══ GREEN LEAF (left side) ══ -->
    <!-- Leaf body -->
    <path
        android:fillColor="#5BAD6F"
        android:pathData="
        M68,120
        C55,95 58,62 75,48
        C88,38 100,55 100,55
        C85,70 75,90 80,115
        C76,118 72,120 68,120 Z"/>
    <!-- Leaf highlight -->
    <path
        android:fillColor="#7DC88A"
        android:pathData="
        M75,48
        C85,42 96,50 100,55
        C90,65 80,78 78,95
        C72,80 68,62 75,48 Z"/>
    <!-- Leaf vein -->
    <path
        android:fillColor="#4A9060"
        android:strokeWidth="1.5"
        android:strokeColor="#4A9060"
        android:fillAlpha="0"
        android:pathData="M75,48 Q80,75 80,115"/>

    <!-- ══ WATER DROP (center-right) ══ -->
    <!-- Drop body -->
    <path
        android:fillColor="#2E9B9B"
        android:pathData="
        M112,48
        C112,48 100,65 100,78
        C100,88 106,96 115,96
        C124,96 130,88 130,78
        C130,65 118,48 112,48 Z"/>
    <!-- Drop highlight -->
    <path
        android:fillColor="#6ECECE"
        android:pathData="
        M108,58
        C105,66 104,72 106,78
        C104,72 106,60 108,58 Z"/>

    <!-- ══ ARROW (pointing up-right, inside drop area) ══ -->
    <!-- Arrow shaft -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:fillAlpha="0"
        android:pathData="M108,90 L120,70"/>
    <!-- Arrow head -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M120,70 L114,72 L118,76 Z"/>
</vector>
